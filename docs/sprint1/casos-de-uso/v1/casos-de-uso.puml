@startuml Casos de Uso - Sistema de Moeda Estudantil

skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #EEF2FF
  BorderColor #4F46E5
  ArrowColor #4F46E5
}
skinparam actor {
  BackgroundColor #DBEAFE
  BorderColor #2563EB
}

left to right direction

actor "Aluno" as A
actor "Professor" as P
actor "Empresa Parceira" as E
actor "Sistema Email" as SE <<system>>

rectangle "Sistema de Moeda Estudantil" {

  package "Autenticação" {
    usecase "UC01\nFazer Login" as UC01
    usecase "UC02\nFazer Logout" as UC02
    usecase "UC03\nCadastrar-se (Aluno)" as UC03
    usecase "UC04\nCadastrar-se (Empresa)" as UC04
  }

  package "Módulo Aluno" {
    usecase "UC05\nVisualizar Dashboard" as UC05
    usecase "UC06\nConsultar Extrato" as UC06
    usecase "UC07\nVer Vantagens Disponíveis" as UC07
    usecase "UC08\nResgatar Vantagem" as UC08
    usecase "UC09\nEditar Perfil" as UC09
  }

  package "Módulo Professor" {
    usecase "UC10\nVisualizar Dashboard" as UC10
    usecase "UC11\nEnviar Moedas para Aluno" as UC11
    usecase "UC12\nConsultar Extrato de Envios" as UC12
  }

  package "Módulo Empresa Parceira" {
    usecase "UC13\nVisualizar Dashboard" as UC13
    usecase "UC14\nCadastrar Vantagem" as UC14
    usecase "UC15\nEditar Vantagem" as UC15
    usecase "UC16\nDesativar Vantagem" as UC16
    usecase "UC17\nEditar Perfil da Empresa" as UC17
  }

  package "Notificações" {
    usecase "UC18\nNotificar Recebimento\nde Moedas (Email)" as UC18
    usecase "UC19\nEnviar Cupom\nao Aluno (Email)" as UC19
    usecase "UC20\nNotificar Empresa\nde Resgate (Email)" as UC20
  }
}

' Aluno
A --> UC01
A --> UC02
A --> UC03
A --> UC05
A --> UC06
A --> UC07
A --> UC08
A --> UC09

' Professor
P --> UC01
P --> UC02
P --> UC10
P --> UC11
P --> UC12

' Empresa
E --> UC01
E --> UC02
E --> UC04
E --> UC13
E --> UC14
E --> UC15
E --> UC16
E --> UC17

' Includes
UC11 .> UC18 : <<include>>
UC08 .> UC19 : <<include>>
UC08 .> UC20 : <<include>>

UC18 --> SE
UC19 --> SE
UC20 --> SE

@enduml
