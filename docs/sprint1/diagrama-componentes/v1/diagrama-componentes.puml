@startuml Diagrama de Componentes - Sistema de Moeda Estudantil

skinparam componentStyle rectangle
skinparam component {
  BackgroundColor #EEF2FF
  BorderColor #4F46E5
  FontSize 11
}
skinparam package {
  BackgroundColor #F8F9FF
  BorderColor #A5B4FC
}
skinparam database {
  BackgroundColor #FEF3C7
  BorderColor #D97706
}
skinparam node {
  BackgroundColor #D1FAE5
  BorderColor #065F46
}
skinparam ArrowColor #4F46E5

' =================== CLIENTE ===================

node "Browser (Cliente)" as Browser {
  [Thymeleaf Templates\n+ Bootstrap 5] as Views
}

' =================== SERVIDOR ===================

node "Spring Boot Application" as App {

  package "controller/" {
    [AuthController] as AC
    [AlunoController] as ALC
    [ProfessorController] as PC
    [EmpresaParceiraController] as ECC
  }

  package "dto/" {
    [CadastroAlunoDTO] as CADTO
    [CadastroEmpresaDTO] as CEDTO
    [EnviarMoedasDTO] as EMDTO
    [VantagemDTO] as VDTO
    [AlunoDashboardDTO] as ADDTO
    [ProfessorDashboardDTO] as PDDTO
    [EmpresaDashboardDTO] as EDDTO
  }

  package "service/" {
    [AlunoService] as AS
    [ProfessorService] as PS
    [EmpresaParceiraService] as ES
    [TransacaoService] as TS
    [VantagemService] as VS
    [EmailService] as EMS
    [UserDetailsServiceImpl] as UDS
  }

  package "exception/" {
    [SaldoInsuficienteException] as SIE
    [UsuarioNaoEncontradoException] as UNE
    [VantagemNaoEncontradaException] as VNE
    [VantagemInativaException] as VIE
    [EmailJaCadastradoException] as EJC
    [CpfCnpjJaCadastradoException] as CCJC
  }

  package "handler/" {
    [GlobalExceptionHandler\n@ControllerAdvice] as GEH
  }

  package "mapper/" {
    [AlunoMapper] as AM
    [VantagemMapper] as VM
  }

  package "event/" {
    [MoedasEnviadasEvent] as MEE
    [VantagemResgatadaEvent] as VRE
  }

  package "repository/ (DAO)" {
    [UsuarioRepository] as UR
    [AlunoRepository] as AR
    [ProfessorRepository] as PR
    [EmpresaParceiraRepository] as ER
    [VantagemRepository] as VR
    [TransacaoEnvioRepository] as TER
    [TransacaoResgateRepository] as TRR
    [InstituicaoRepository] as IR
  }

  package "model/" {
    [Usuario / Aluno / Professor\nEmpresaParceira / Instituicao\nVantagem / Transacao\nTransacaoEnvio / TransacaoResgate] as Entities
  }

  package "model/enums/" {
    [TipoUsuario\nTipoTransacao] as Enums
  }

  package "config/" {
    [SecurityConfig] as SC
    [DataInitializer] as DI
    [WebConfig] as WC
  }

  package "security/" {
    [SecurityUtils] as SU
  }

  package "util/" {
    [CpfCnpjUtils] as CPU
    [MoedaUtils] as MU
  }

  package "constant/" {
    [AppConstants] as CONST
  }
}

' =================== INFRAESTRUTURA ===================

database "PostgreSQL\n(moeda_estudantil)" as DB
[SMTP Server\n(Email)] as SMTP
[File System\n(/uploads)] as FS

' =================== CONEXÕES — CONTROLLER → SERVICE ===================

Browser --> AC : HTTP GET/POST
Browser --> ALC : HTTP GET/POST
Browser --> PC : HTTP GET/POST
Browser --> ECC : HTTP GET/POST

AC --> AS
AC --> ES
ALC --> AS
ALC --> TS
ALC --> VS
PC --> PS
PC --> TS
ECC --> ES
ECC --> VS

' =================== SERVICE → REPO ===================

AS --> AR
AS --> UR
AS --> IR
PS --> PR
ES --> ER
ES --> UR
TS --> TER
TS --> TRR
TS --> PR
TS --> AR
TS --> VR
TS --> EMS
VS --> VR
VS --> FS : salva fotos

' =================== SERVICE → EVENTS ===================

TS --> MEE : publica
TS --> VRE : publica

' =================== SERVICE → EXCEPTIONS ===================

TS --> SIE : lança
TS --> UNE : lança
TS --> VNE : lança
TS --> VIE : lança
AS --> EJC : lança
AS --> CCJC : lança

GEH --> SIE : trata
GEH --> UNE : trata
GEH --> VNE : trata

' =================== MAPPER → DTO/ENTITY ===================

AM --> CADTO
AM --> Entities
VM --> VDTO
VM --> Entities

' =================== REPO → ENTITY / DB ===================

AR --> Entities
PR --> Entities
ER --> Entities
VR --> Entities
TER --> Entities
TRR --> Entities
UR --> Entities
IR --> Entities

Entities --> Enums
Entities --> DB : JPA/Hibernate

' =================== INFRAESTRUTURA ===================

EMS --> SMTP : JavaMailSender

SC --> UDS
UDS --> UR

SU --> SC : SecurityContext
MU --> CONST
CPU --> CONST

DI --> IR
DI --> PR
WC --> FS : resource handler

@enduml
