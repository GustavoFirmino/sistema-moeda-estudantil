@startuml Diagrama de Componentes - Sistema de Moeda Estudantil

skinparam componentStyle rectangle
skinparam component {
  BackgroundColor #EEF2FF
  BorderColor #4F46E5
  FontSize 12
}
skinparam database {
  BackgroundColor #FEF3C7
  BorderColor #D97706
}
skinparam node {
  BackgroundColor #D1FAE5
  BorderColor #065F46
}
skinparam ArrowColor #4F46E5

' =================== CLIENTE ===================

node "Browser (Cliente)" as Browser {
  [Thymeleaf Templates\n+ Bootstrap 5] as Views
}

' =================== SERVIDOR ===================

node "Spring Boot Application" as App {

  package "Controller Layer" {
    [AuthController] as AC
    [AlunoController] as ALC
    [ProfessorController] as PC
    [EmpresaParceiraController] as ECC
  }

  package "Service Layer" {
    [AlunoService] as AS
    [ProfessorService] as PS
    [EmpresaParceiraService] as ES
    [TransacaoService] as TS
    [VantagemService] as VS
    [EmailService] as EMS
  }

  package "Security" {
    [SecurityConfig] as SC
    [UserDetailsServiceImpl] as UDS
  }

  package "Repository Layer" {
    [UsuarioRepository] as UR
    [AlunoRepository] as AR
    [ProfessorRepository] as PR
    [EmpresaParceiraRepository] as ER
    [VantagemRepository] as VR
    [TransacaoEnvioRepository] as TER
    [TransacaoResgateRepository] as TRR
  }

  package "Model (JPA Entities)" {
    [Usuario / Aluno / Professor\nEmpresaParceira / Instituicao\nVantagem / Transacao] as Entities
  }
}

' =================== INFRAESTRUTURA ===================

database "PostgreSQL\n(moeda_estudantil)" as DB
[SMTP Server\n(Email)] as SMTP
[File System\n(/uploads)] as FS

' =================== CONEXÕES ===================

Browser --> AC : HTTP GET/POST
Browser --> ALC : HTTP GET/POST
Browser --> PC : HTTP GET/POST
Browser --> ECC : HTTP GET/POST

AC --> AS
AC --> ES
ALC --> AS
ALC --> TS
ALC --> VS
PC --> PS
PC --> TS
ECC --> ES
ECC --> VS

AS --> AR
AS --> UR
PS --> PR
ES --> ER
ES --> UR
TS --> TER
TS --> TRR
TS --> PR
TS --> AR
TS --> VR
TS --> EMS
VS --> VR
VS --> FS : salva fotos

AR --> Entities
PR --> Entities
ER --> Entities
VR --> Entities
TER --> Entities
TRR --> Entities
UR --> Entities

Entities --> DB : JPA/Hibernate

EMS --> SMTP : JavaMailSender

SC --> UDS
UDS --> UR

@enduml
